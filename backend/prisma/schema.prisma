generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String?
  role          Role           @default(CANDIDATE)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  companyId     String?
  company       Company?       @relation(fields: [companyId], references: [id])
  ownedCompanies Company[]      @relation("CompanyOwner")
  refreshTokens RefreshToken[]
}

model Company {
  id            String            @id @default(uuid())
  name          String
  slug          String            @unique
  ownerId       String
  owner         User              @relation("CompanyOwner", fields: [ownerId], references: [id])
  users         User[]
  jobs          Job[]
  careerPageUrl String?
  websiteUrl    String?
  logo          String?
  description   String?
  email         String?
  phone         String?
  address       String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  settings      CompanySettings?
}

model CompanySettings {
  id             String   @id @default(uuid())
  companyId      String   @unique
  company        Company  @relation(fields: [companyId], references: [id])
  locale         String?
  timezone       String?
  billingEmail   String?
  timezoneOffset Int?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  SUPER_ADMIN
  HR
  CANDIDATE
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

model Job {
  id             String    @id @default(uuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id])
  title          String
  department     String?
  employmentType String?
  workMode       String?
  location       String?
  salaryMin      Int?
  salaryMax      Int?
  experience     String?
  openPositions   Int?      @default(1)
  applications    Int       @default(0)
  skills          String?
  qualifications  String?
  description     String?
  responsibilities String?
  requirements    String?
  benefits        String?
  deadline        DateTime?
  status          JobStatus @default(DRAFT)
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
