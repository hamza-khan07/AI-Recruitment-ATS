generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String?
  role          Role           @default(CANDIDATE)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  companyId     String?
  company       Company?       @relation(fields: [companyId], references: [id])
  ownedCompanies Company[]      @relation("CompanyOwner")
  refreshTokens RefreshToken[]
  candidateProfile CandidateProfile?
  applications  Application[]  @relation("CandidateApplications")
}

model CandidateProfile {
  id             String           @id @default(uuid())
  userId         String           @unique
  user           User             @relation(fields: [userId], references: [id])
  title          String?
  bio            String?
  phone          String?
  location       String?
  linkedinUrl    String?
  portfolioUrl   String?
  resumeUrl      String?
  avatar         String?
  skills         String[]
  workExperience WorkExperience[]
  education      Education[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model WorkExperience {
  id                 String           @id @default(uuid())
  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  role               String
  company            String
  startDate          String?
  endDate            String?
  current            Boolean          @default(false)
  description        String?
}

model Education {
  id                 String           @id @default(uuid())
  candidateProfileId String
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  degree             String
  field              String?
  institution        String
  startYear          String?
  endYear            String?
  current            Boolean          @default(false)
}

model Company {
  id            String            @id @default(uuid())
  name          String
  slug          String            @unique
  ownerId       String
  owner         User              @relation("CompanyOwner", fields: [ownerId], references: [id])
  users         User[]
  jobs          Job[]
  careerPageUrl String?
  websiteUrl    String?
  logo          String?
  description   String?
  email         String?
  phone         String?
  address       String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  size          String?
  settings      CompanySettings?
}

model CompanySettings {
  id             String   @id @default(uuid())
  companyId      String   @unique
  company        Company  @relation(fields: [companyId], references: [id])
  locale         String?
  timezone       String?
  billingEmail   String?
  timezoneOffset Int?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  SUPER_ADMIN
  HR
  CANDIDATE
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

model Job {
  id             String        @id @default(uuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])
  title          String
  department     String?
  employmentType String?
  workMode       String?
  location       String?
  salaryMin      Int?
  salaryMax      Int?
  experience     String?
  openPositions  Int?          @default(1)
  applications   Int           @default(0)
  skills         String?
  qualifications String?
  description    String?
  responsibilities String?
  requirements   String?
  benefits       String?
  deadline       DateTime?
  status         JobStatus     @default(DRAFT)
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  jobApplications Application[]
}

enum ApplicationStatus {
  APPLIED
  IN_REVIEW
  SHORTLISTED
  INTERVIEW
  REJECTED
  HIRED
}

model Application {
  id           String            @id @default(uuid())
  jobId        String
  job          Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId  String
  candidate    User              @relation("CandidateApplications", fields: [candidateId], references: [id])
  fullName     String
  email        String
  phone        String?
  resumeUrl    String?
  coverLetter  String?
  status       ApplicationStatus @default(APPLIED)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([jobId, candidateId])
}

